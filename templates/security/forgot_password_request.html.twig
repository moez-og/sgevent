{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.forgot_password.title'|trans }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/auth.css') }}?v=20260411b">
{% endblock %}

{% block body %}
    <div class="auth-page auth-page--login">
        <div class="auth-layout" style="grid-template-columns:1fr;max-width:720px;">
            <section class="auth-form-wrap" style="width:100%;">
                <div class="auth-card">
                    <p class="auth-kicker">{{ 'auth.forgot_password.kicker'|trans }}</p>
                    <h1 class="auth-title">{{ 'auth.forgot_password.title'|trans }}</h1>
                    <p class="auth-subtitle">{{ 'auth.forgot_password.subtitle'|trans }}</p>

                    {% for message in app.flashes('success') %}
                        <div class="auth-success">{{ message }}</div>
                    {% endfor %}

                    {% for message in app.flashes('error') %}
                        <div class="auth-error">{{ message }}</div>
                    {% endfor %}

                    <form method="post" novalidate>
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password_request') }}">

                        <div class="auth-field">
                            <label for="email">{{ 'auth.email'|trans }}</label>
                            <input id="email" type="email" name="email" value="{{ last_email|default('') }}" required>
                        </div>

                        <button class="auth-submit" type="submit">
                            <span class="auth-submit__label">{{ 'auth.forgot_password.send_otp'|trans }}</span>
                            <span class="auth-submit__spinner" aria-hidden="true"></span>
                        </button>
                    </form>

                    <p class="auth-footer"><a href="{{ path('app_login') }}">{{ 'auth.back_to_login'|trans }}</a></p>
                </div>
            </section>
        </div>
    </div>
{% endblock %}
