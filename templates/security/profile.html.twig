{% extends 'front/base_front.html.twig' %}

{% block title %}Mon profil | Fin Tokhroj{% endblock %}

{% block front_content %}
    <section class="app-card" style="padding:24px;">
        <div class="section-head" style="margin-bottom:14px;">
            <div>
                <h2 class="section-title" style="margin:0;">Modifier mon compte</h2>
                <p class="section-subtitle" style="margin-top:6px;">Mets a jour tes informations personnelles.</p>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="sortie-flash sortie-flash-success">{{ message }}</div>
        {% endfor %}

        {% set profileRawImage = app.user ? (app.user.imageUrl|default('')) : '' %}
        {% if profileRawImage and (profileRawImage starts with 'http://' or profileRawImage starts with 'https://') %}
            {% set profileImageSrc = profileRawImage %}
        {% elseif profileRawImage and (profileRawImage starts with 'theme/' or profileRawImage starts with 'uploads/') %}
            {% set profileImageSrc = asset(profileRawImage) %}
        {% elseif profileRawImage and profileRawImage != 'default.png' %}
            {% set profileImageSrc = asset('uploads/users/' ~ profileRawImage) %}
        {% else %}
            {% set profileImageSrc = asset('theme/images/logo.png') %}
        {% endif %}

        <div style="display:flex;align-items:center;gap:12px;margin-bottom:18px;padding:12px;border:1px solid rgba(20,61,113,.1);border-radius:16px;background:rgba(255,255,255,.75);">
            <img src="{{ profileImageSrc }}" alt="photo profil" style="width:56px;height:56px;border-radius:14px;object-fit:cover;" onerror="this.onerror=null;this.src='{{ asset('theme/images/logo.png') }}';">
            <div>
                <div style="font-weight:800;color:var(--ft-text);">{{ app.user.prenom|default('') }} {{ app.user.nom|default('') }}</div>
                <div style="font-size:.82rem;color:var(--ft-muted);">{{ app.user.email|default('') }}</div>
            </div>
        </div>

        {{ form_start(form, {attr: {class: 'users-form-grid'}}) }}
            <div class="form-row two" style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;">
                <div class="form-group" style="display:grid;gap:6px;">
                    {{ form_label(form.prenom) }}
                    {{ form_widget(form.prenom, {attr: {class: 'custom-input'}}) }}
                    {{ form_errors(form.prenom) }}
                </div>

                <div class="form-group" style="display:grid;gap:6px;">
                    {{ form_label(form.nom) }}
                    {{ form_widget(form.nom, {attr: {class: 'custom-input'}}) }}
                    {{ form_errors(form.nom) }}
                </div>
            </div>

            <div class="form-row two" style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-top:12px;">
                <div class="form-group" style="display:grid;gap:6px;">
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email, {attr: {class: 'custom-input'}}) }}
                    {{ form_errors(form.email) }}
                </div>

                <div class="form-group" style="display:grid;gap:6px;">
                    {{ form_label(form.telephone) }}
                    {{ form_widget(form.telephone, {attr: {class: 'custom-input'}}) }}
                    {{ form_errors(form.telephone) }}
                </div>
            </div>

            <div class="form-group" style="display:grid;gap:6px;margin-top:12px;">
                {{ form_label(form.image) }}
                {{ form_widget(form.image, {attr: {class: 'custom-input'}}) }}
                {{ form_errors(form.image) }}
            </div>

            <div style="margin-top:16px;display:flex;justify-content:flex-end;">
                <button type="submit" class="primary-btn">Enregistrer les modifications</button>
            </div>
        {{ form_end(form) }}
    </section>
{% endblock %}
