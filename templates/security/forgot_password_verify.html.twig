{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.otp_verify.title'|trans }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/auth.css') }}?v=20260411b">
{% endblock %}

{% block body %}
    <div class="auth-page auth-page--login">
        <div class="auth-layout" style="grid-template-columns:1fr;max-width:760px;">
            <section class="auth-form-wrap" style="width:100%;">
                <div class="auth-card">
                    <p class="auth-kicker">{{ 'auth.otp_verify.kicker'|trans }}</p>
                    <h1 class="auth-title">{{ 'auth.otp_verify.title'|trans }}</h1>
                    <p class="auth-subtitle">{{ 'auth.otp_verify.subtitle'|trans({'%email%': email, '%minutes%': (expires_in / 60)|round(0, 'floor') }) }}</p>

                    {% for message in app.flashes('success') %}
                        <div class="auth-success">{{ message }}</div>
                    {% endfor %}

                    {% for message in app.flashes('error') %}
                        <div class="auth-error">{{ message }}</div>
                    {% endfor %}

                    <form method="post" novalidate>
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password_verify') }}">

                        <div class="auth-field">
                            <label for="otp">{{ 'auth.otp_verify.otp_code'|trans }}</label>
                            <input id="otp" type="text" name="otp" inputmode="numeric" pattern="\d{6}" maxlength="6" required>
                        </div>

                        <div class="auth-field">
                            <label for="new_password">{{ 'auth.new_password'|trans }}</label>
                            <input id="new_password" type="password" name="new_password" required>
                        </div>

                        <div class="auth-field">
                            <label for="confirm_password">{{ 'auth.confirm_password'|trans }}</label>
                            <input id="confirm_password" type="password" name="confirm_password" required>
                        </div>

                        <button class="auth-submit" type="submit">
                            <span class="auth-submit__label">{{ 'auth.otp_verify.validate_reset'|trans }}</span>
                            <span class="auth-submit__spinner" aria-hidden="true"></span>
                        </button>
                    </form>

                    <p class="auth-footer"><a href="{{ path('app_forgot_password_request') }}">{{ 'auth.otp_verify.resend_code'|trans }}</a></p>
                </div>
            </section>
        </div>
    </div>
{% endblock %}
