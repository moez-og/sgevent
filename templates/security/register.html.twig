{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.register'|trans }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/auth.css') }}?v=20260418v3">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('theme/js/auth-wow.js') }}?v=20260410c" defer></script>
    <script src="{{ asset('theme/js/tunisia-map-gis.js') }}?v=20260411a" defer></script>
{% endblock %}

{% block body %}
    <div class="auth-page auth-page--register">
        <div class="auth-ambient" aria-hidden="true">
            <span class="auth-orb auth-orb--one"></span>
            <span class="auth-orb auth-orb--two"></span>
            <span class="auth-orb auth-orb--three"></span>
            <span class="auth-grid-glow"></span>
        </div>
        <div class="auth-layout">
            <aside class="auth-visual">
                {% include 'security/_tunisia_map_panel.html.twig' %}
                <div class="auth-visual-overlay"></div>
                <div class="auth-brand">FinTokhroj Experience</div>
                <div class="auth-tagline">
                    <h2>Commence ton aventure</h2>
                    <p>Cree ton compte pour acceder aux reservations, favoris et alertes.</p>
                </div>
            </aside>

            <section class="auth-form-wrap">
                <div class="auth-switch"><a href="{{ path('app_login') }}">{{ 'auth.login'|trans }}</a></div>

                <div class="auth-card">
                    <p class="auth-kicker">{{ 'auth.new_account'|trans }}</p>
                    <h1 class="auth-title">{{ 'auth.create_account'|trans }}</h1>
                    <p class="auth-subtitle">{{ 'auth.register_subtitle'|trans }}</p>

                    <a href="{{ path('app_connect_google_start') }}" class="auth-google-btn" style="text-decoration:none;">
                        <span class="auth-google-btn__icon">G</span>
                        <span>{{ 'auth.google_continue'|trans }}</span>
                    </a>
                    <div class="auth-google-sep"><span>{{ 'auth.or_classic_signup'|trans }}</span></div>

                    {{ form_start(form, { attr: { novalidate: 'novalidate', 'data-auth-morph': 'true' } }) }}

                        <div class="auth-field">
                            {{ form_label(form.nom) }}
                            {{ form_widget(form.nom, {
                                attr: {
                                    class: form.nom.vars.errors|length ? 'is-invalid' : '',
                                    minlength: 2,
                                    maxlength: 50,
                                    pattern: "[A-Za-zÀ-ÿ\\s\\-']+",
                                    title: '2 a 50 lettres, espaces, tirets ou apostrophes.'
                                }
                            }) }}
                            <div class="auth-field-error">{{ form_errors(form.nom) }}</div>
                        </div>

                        <div class="auth-field">
                            {{ form_label(form.prenom) }}
                            {{ form_widget(form.prenom, {
                                attr: {
                                    class: form.prenom.vars.errors|length ? 'is-invalid' : '',
                                    minlength: 2,
                                    maxlength: 50,
                                    pattern: "[A-Za-zÀ-ÿ\\s\\-']+",
                                    title: '2 a 50 lettres, espaces, tirets ou apostrophes.'
                                }
                            }) }}
                            <div class="auth-field-error">{{ form_errors(form.prenom) }}</div>
                        </div>

                        <div class="auth-field">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email, {
                                attr: {
                                    class: form.email.vars.errors|length ? 'is-invalid' : '',
                                    maxlength: 180
                                }
                            }) }}
                            <div class="auth-field-error">{{ form_errors(form.email) }}</div>
                        </div>

                        <div class="auth-field">
                            {{ form_label(form.telephone) }}
                            {{ form_widget(form.telephone, {
                                attr: {
                                    class: form.telephone.vars.errors|length ? 'is-invalid' : '',
                                    pattern: '^\\+?[0-9\\s\\-]{8,16}$',
                                    title: 'Ex: +216 12 345 678'
                                }
                            }) }}
                            <div class="auth-field-error">{{ form_errors(form.telephone) }}</div>
                        </div>

                        <div class="auth-field">
                            {{ form_label(form.image) }}
                            {{ form_widget(form.image, {
                                attr: {
                                    class: form.image.vars.errors|length ? 'is-invalid' : '',
                                    accept: 'image/png,image/jpeg,image/webp'
                                }
                            }) }}
                            <div class="auth-field-error">{{ form_errors(form.image) }}</div>
                        </div>

                        <div class="auth-field">
                            {{ form_label(form.plainPassword.first) }}
                            {{ form_widget(form.plainPassword.first, {
                                attr: {
                                    class: form.plainPassword.first.vars.errors|length ? 'is-invalid' : '',
                                    minlength: 8,
                                    pattern: '(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[^\\w\\s]).{8,}',
                                    title: 'Min 8 caracteres avec majuscule, minuscule, chiffre et caractere special.'
                                }
                            }) }}
                            <div class="auth-field-error">{{ form_errors(form.plainPassword.first) }}</div>
                        </div>

                        <div class="auth-field">
                            {{ form_label(form.plainPassword.second) }}
                            {{ form_widget(form.plainPassword.second, {
                                attr: {
                                    class: form.plainPassword.second.vars.errors|length ? 'is-invalid' : '',
                                    minlength: 8
                                }
                            }) }}
                            <div class="auth-field-error">{{ form_errors(form.plainPassword.second) }}</div>
                        </div>

                        <button class="auth-submit" type="submit">
                            <span class="auth-submit__label">{{ 'auth.create_my_account'|trans }}</span>
                            <span class="auth-submit__spinner" aria-hidden="true"></span>
                        </button>
                    {{ form_end(form) }}

                    <p class="auth-footer">{{ 'auth.already_account'|trans }} <a href="{{ path('app_login') }}">{{ 'auth.login_now'|trans }}</a></p>
                </div>
            </section>
        </div>
    </div>
{% endblock %}
