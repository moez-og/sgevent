{% extends 'admin/base_admin.html.twig' %}

{% block title %}Admin - Ajouter sortie | Fin Tokhroj{% endblock %}
{% block admin_page_title %}Ajouter une sortie{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'sortie/_form_styles.html.twig' only %}
{% endblock %}

{% block admin_content %}
<section>
    <div class="section-head">
        <div>
            <h2 class="section-title">Créer une annonce sortie</h2>
            <p class="section-subtitle">Version admin avec gestion du statut.</p>
        </div>
        <a href="{{ path('app_admin_sorties') }}" class="outline-btn"><span class="btn-icon">&larr;</span>Retour liste admin</a>
    </div>

    {% include 'sortie/_form.html.twig' with {
        form: form,
        cancel_path: path('app_admin_sorties'),
        submit_label: 'Créer annonce'
    } %}
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% include 'sortie/_form_scripts.html.twig' with { form: form } only %}
{% endblock %}
