<header class="admin-topbar">
    {% set currentLocale = app.request.locale|default('fr') %}
    {% set currentUrl = app.request.uri %}
    <div>
        <h1>{% block admin_page_title %}{{ 'admin.dashboard'|trans }}{% endblock %}</h1>
        <p>{{ 'admin.overview'|trans }} — <span data-refresh-date></span></p>
    </div>
    <div class="front-tools">
        <form class="search-pill" method="get" action="{{ path('app_admin_users') }}" data-admin-search-form>
            <span>🔎</span>
            <input type="text" name="q" value="{{ app.request.query.get('q') }}" placeholder="{{ 'admin.search_placeholder'|trans }}" data-admin-search-input>
        </form>
        <div class="locale-switch" aria-label="{{ 'nav.language'|trans }}">
            <a href="{{ path('app_set_locale', { locale: 'fr' }) ~ '?redirect=' ~ currentUrl|url_encode }}" class="{{ currentLocale == 'fr' ? 'active' : '' }}">FR</a>
            <a href="{{ path('app_set_locale', { locale: 'en' }) ~ '?redirect=' ~ currentUrl|url_encode }}" class="{{ currentLocale == 'en' ? 'active' : '' }}">EN</a>
            <a href="{{ path('app_set_locale', { locale: 'ar' }) ~ '?redirect=' ~ currentUrl|url_encode }}" class="{{ currentLocale == 'ar' ? 'active' : '' }}">AR</a>
        </div>
        <button class="outline-btn">{{ 'admin.refresh'|trans }}</button>
        {% set adminRawImage = app.user ? (app.user.imageUrl|default('')) : '' %}
        {% if adminRawImage and (adminRawImage starts with 'http://' or adminRawImage starts with 'https://') %}
            {% set adminImageSrc = adminRawImage %}
        {% elseif adminRawImage and (adminRawImage starts with '/theme/' or adminRawImage starts with '/uploads/') %}
            {% set adminImageSrc = asset(adminRawImage|trim('/')) %}
        {% elseif adminRawImage and (adminRawImage starts with 'theme/' or adminRawImage starts with 'uploads/') %}
            {% set adminImageSrc = asset(adminRawImage|trim('/')) %}
        {% elseif adminRawImage and (adminRawImage starts with '/public/' or adminRawImage starts with 'public/') %}
            {% set adminImageSrc = asset(adminRawImage|replace({'/public/': '', 'public/': ''})|trim('/')) %}
        {% elseif adminRawImage and ('uploads/' in adminRawImage) %}
            {% set adminImageSrc = asset(adminRawImage|split('uploads/')|last|trim('/')|replace({'users/': 'uploads/users/'}) ) %}
        {% elseif adminRawImage and adminRawImage != 'default.png' %}
            {% set adminImageSrc = asset('uploads/users/' ~ adminRawImage|trim('/')) %}
        {% else %}
            {% set adminImageSrc = asset('theme/images/logo.png') %}
        {% endif %}
        <div class="user-profile-root" data-profile-root>
            <div class="user-chip">
                <img class="avatar-circle" src="{{ adminImageSrc }}" alt="Admin" onerror="this.onerror=null;this.src='{{ asset('theme/images/logo.png') }}';">
                <button type="button" class="user-chip__identity" data-profile-toggle aria-expanded="false" aria-controls="admin-profile-panel">
                    <div class="user-chip__name">{{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'Admin' }}</div>
                    <div class="user-chip__role">{{ app.user ? app.user.role|upper : 'ADMIN' }}</div>
                </button>
            </div>

            <aside id="admin-profile-panel" class="profile-panel" data-profile-panel aria-hidden="true" role="dialog" aria-label="{{ 'admin.profile'|trans }}" hidden>
                <div class="profile-panel__head">
                    <img class="profile-panel__avatar" src="{{ adminImageSrc }}" alt="photo profil" onerror="this.onerror=null;this.src='{{ asset('theme/images/logo.png') }}';">
                    <div>
                        <div class="profile-panel__name">{{ app.user ? app.user.prenom : 'Admin' }}</div>
                        <div class="profile-panel__role">{{ app.user ? app.user.role|upper : 'ADMIN' }}</div>
                    </div>
                </div>

                <div class="profile-panel__meta">
                    <span>{{ 'profile.first_name'|trans }}</span>
                    <strong>{{ app.user ? app.user.prenom : 'Admin' }}</strong>
                    <span>{{ 'profile.last_name'|trans }}</span>
                    <strong>{{ app.user ? app.user.nom : '' }}</strong>
                    <span>{{ 'profile.email'|trans }}</span>
                    <strong>{{ app.user ? app.user.email : '' }}</strong>
                </div>

                <div class="profile-panel__actions">
                    <a href="{{ path('app_admin_profile') }}" class="cta-btn" style="text-decoration:none;display:inline-flex;align-items:center;justify-content:center;">{{ 'profile.edit_account'|trans }}</a>
                </div>
            </aside>
        </div>
        <a href="{{ path('app_logout') }}" class="cta-btn" style="text-decoration:none;display:inline-flex;align-items:center;">{{ 'auth.logout'|trans }}</a>
    </div>
</header>