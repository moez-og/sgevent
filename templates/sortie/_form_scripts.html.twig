<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
    (function () {
        function parseLatLng(raw) {
            if (!raw || typeof raw !== 'string') return null;
            const parts = raw.split(',').map(function (x) { return Number(String(x).trim()); });
            if (parts.length !== 2 || Number.isNaN(parts[0]) || Number.isNaN(parts[1])) return null;
            return parts;
        }

        function ready(fn) {
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', fn);
            } else {
                fn();
            }
        }

        ready(function () {
            const dateSortieInput = document.getElementById('{{ form.date_sortie.vars.id }}');
            if (dateSortieInput && typeof flatpickr === 'function') {
                const minDaysRaw = Number(dateSortieInput.getAttribute('data-min-days') || '1');
                const minDays = Number.isFinite(minDaysRaw) ? minDaysRaw : 1;
                const minDate = new Date();
                minDate.setDate(minDate.getDate() + Math.max(0, minDays));

                flatpickr(dateSortieInput, {
                    enableTime: true,
                    time_24hr: true,
                    dateFormat: 'Y-m-d H:i',
                    altInput: true,
                    altFormat: 'd/m/Y H:i',
                    minuteIncrement: 5,
                    minDate,
                    disableMobile: true,
                    locale: (flatpickr.l10ns && flatpickr.l10ns.fr) ? flatpickr.l10ns.fr : undefined,
                });
            }

            const mapEl = document.getElementById('sortie-map');
            if (!mapEl || typeof L === 'undefined') return;

            const cityInput = document.getElementById('{{ form.ville.vars.id }}');
            const pointInput = document.getElementById('{{ form.point_rencontre.vars.id }}');
            const mapSearchInput = document.getElementById('sortie-map-search');
            const mapSearchSuggestions = document.getElementById('sortie-map-suggestions');
            const activityInput = document.getElementById('{{ form.type_activite.vars.id }}');
            const activityOtherWrap = document.getElementById('type-activite-autre-wrap');
            const activityOtherInput = document.getElementById('{{ form.type_activite_autre.vars.id }}');
            const freeInput = document.getElementById('{{ form.budget_gratuit.vars.id }}');
            const budgetInput = document.getElementById('{{ form.budget_max.vars.id }}');
            const questionsInput = document.getElementById('{{ form.questions_json.vars.id }}');
            const questionInput = document.getElementById('question-input');
            const questionAdd = document.getElementById('question-add');
            const questionList = document.getElementById('question-list');

            const cityCoords = {
                'Tunis': [36.8065, 10.1815], 'Ariana': [36.8625, 10.1956], 'Ben Arous': [36.7545, 10.2217],
                'Manouba': [36.8080, 10.0958], 'Nabeul': [36.4561, 10.7376], 'Zaghouan': [36.4029, 10.1429],
                'Bizerte': [37.2744, 9.8739], 'Beja': [36.7333, 9.1833], 'Jendouba': [36.5011, 8.7800],
                'Kef': [36.1742, 8.7049], 'Siliana': [36.0833, 9.3667], 'Sousse': [35.8256, 10.6411],
                'Monastir': [35.7770, 10.8262], 'Mahdia': [35.5047, 11.0622], 'Sfax': [34.7406, 10.7603],
                'Kairouan': [35.6781, 10.0963], 'Kasserine': [35.1674, 8.8365], 'Sidi Bouzid': [35.0382, 9.4849],
                'Gabes': [33.8815, 10.0982], 'Medenine': [33.3549, 10.5055], 'Tataouine': [32.9297, 10.4518],
                'Gafsa': [34.4250, 8.7842], 'Tozeur': [33.9197, 8.1335], 'Kebili': [33.7044, 8.9690]
            };

            const defaultCenter = [34.0, 9.0];
            const initialPoint = parseLatLng(pointInput ? pointInput.value : '');
            const initialCity = cityInput ? cityInput.value : '';
            const initialCenter = initialPoint || cityCoords[initialCity] || defaultCenter;

            const map = L.map(mapEl, {
                zoomControl: true,
                preferCanvas: true,
                zoomAnimation: true,
                markerZoomAnimation: true,
                inertia: true,
            }).setView(initialCenter, initialPoint ? 13 : 6);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            let marker = L.marker(initialCenter, { draggable: true }).addTo(map);
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            function updatePointInput(latlng) {
                if (!pointInput) return;
                pointInput.value = latlng.lat.toFixed(6) + ',' + latlng.lng.toFixed(6);
            }
            function setMarkerAndSync(latlng) {
                marker.setLatLng(latlng);
                updatePointInput(marker.getLatLng());
            }

            function invalidateMapSize() {
                map.invalidateSize({ animate: false, pan: false });
            }

            requestAnimationFrame(invalidateMapSize);
            setTimeout(invalidateMapSize, 220);
            window.addEventListener('resize', invalidateMapSize);
            if ('ResizeObserver' in window) {
                const ro = new ResizeObserver(function () {
                    invalidateMapSize();
                });
                ro.observe(mapEl);
            }

            updatePointInput(marker.getLatLng());
            marker.on('dragend', function () { updatePointInput(marker.getLatLng()); });
            map.on('click', function (e) {
                setMarkerAndSync(e.latlng);
            });

            let addressSearchTimer = null;
            let addressAbortController = null;

            function hideAddressSuggestions() {
                if (!mapSearchSuggestions) return;
                mapSearchSuggestions.hidden = true;
                mapSearchSuggestions.innerHTML = '';
            }

            function renderAddressSuggestions(items) {
                if (!mapSearchSuggestions) return;

                if (!Array.isArray(items) || items.length === 0) {
                    mapSearchSuggestions.innerHTML = '<div class="map-search-empty">Aucune adresse trouvée.</div>';
                    mapSearchSuggestions.hidden = false;
                    return;
                }

                mapSearchSuggestions.innerHTML = items.map(function (item, idx) {
                    const name = String(item.display_name || '').replace(/"/g, '&quot;');
                    const lat = String(item.lat || '');
                    const lon = String(item.lon || '');
                    const shortLabel = name.split(',').slice(0, 2).join(',').trim() || name;

                    return '<button type="button" class="map-search-suggestion" data-lat="' + lat + '" data-lon="' + lon + '" data-label="' + name + '">'
                        + shortLabel
                        + '<small>' + name + '</small>'
                        + '</button>';
                }).join('');

                mapSearchSuggestions.hidden = false;

                mapSearchSuggestions.querySelectorAll('.map-search-suggestion').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        const lat = Number(btn.getAttribute('data-lat'));
                        const lon = Number(btn.getAttribute('data-lon'));
                        if (Number.isNaN(lat) || Number.isNaN(lon)) return;

                        const coords = [lat, lon];
                        if (mapSearchInput) {
                            mapSearchInput.value = btn.getAttribute('data-label') || '';
                        }

                        map.flyTo(coords, 14, { duration: 0.7 });
                        setMarkerAndSync(coords);
                        hideAddressSuggestions();
                    });
                });
            }

            async function searchAddressSuggestions(query) {
                if (!query || query.trim().length < 3) {
                    hideAddressSuggestions();
                    return;
                }

                if (addressAbortController) {
                    addressAbortController.abort();
                }
                addressAbortController = new AbortController();

                const url = 'https://nominatim.openstreetmap.org/search?format=jsonv2&addressdetails=1&countrycodes=tn&limit=6&q=' + encodeURIComponent(query);

                try {
                    const response = await fetch(url, {
                        method: 'GET',
                        signal: addressAbortController.signal,
                        headers: {
                            'Accept': 'application/json'
                        }
                    });

                    if (!response.ok) {
                        hideAddressSuggestions();
                        return;
                    }

                    const payload = await response.json();
                    renderAddressSuggestions(Array.isArray(payload) ? payload : []);
                } catch (_) {
                    hideAddressSuggestions();
                }
            }

            if (mapSearchInput) {
                mapSearchInput.addEventListener('input', function () {
                    const query = mapSearchInput.value;
                    if (addressSearchTimer) {
                        window.clearTimeout(addressSearchTimer);
                    }
                    addressSearchTimer = window.setTimeout(function () {
                        searchAddressSuggestions(query);
                    }, 220);
                });

                mapSearchInput.addEventListener('focus', function () {
                    if (mapSearchInput.value.trim().length >= 3) {
                        searchAddressSuggestions(mapSearchInput.value.trim());
                    }
                });
            }

            document.addEventListener('click', function (event) {
                const target = event.target;
                if (!mapSearchSuggestions || !mapSearchInput) return;
                if (mapSearchSuggestions.contains(target) || mapSearchInput.contains(target)) return;
                hideAddressSuggestions();
            });

            async function fetchCityCoordinates(cityName) {
                if (!cityName) return null;

                const query = encodeURIComponent(cityName + ', Tunisia');
                const url = `https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${query}`;

                try {
                    const response = await fetch(url, {
                        headers: {
                            'Accept': 'application/json'
                        }
                    });

                    if (!response.ok) return null;
                    const payload = await response.json();
                    if (!Array.isArray(payload) || payload.length === 0) return null;

                    const lat = Number(payload[0].lat);
                    const lon = Number(payload[0].lon);
                    if (Number.isNaN(lat) || Number.isNaN(lon)) return null;

                    return [lat, lon];
                } catch (_) {
                    return null;
                }
            }

            async function recenterToCity(cityName, syncMarker) {
                if (!cityName) return;

                let coords = cityCoords[cityName] || null;
                if (!coords) {
                    coords = await fetchCityCoordinates(cityName);
                    if (coords) {
                        cityCoords[cityName] = coords;
                    }
                }

                if (!coords) {
                    coords = defaultCenter;
                }

                if (prefersReducedMotion) {
                    map.setView(coords, 11);
                } else {
                    map.flyTo(coords, 11, { duration: 0.7 });
                }
                if (syncMarker) {
                    setMarkerAndSync(coords);
                }
            }

            if (cityInput) {
                cityInput.addEventListener('change', function () {
                    recenterToCity(cityInput.value, true);
                });

                // On create pages, city immediately drives map center and marker.
                // On edit pages, keep the saved marker position if already present.
                if (!initialPoint && cityInput.value) {
                    recenterToCity(cityInput.value, true);
                }
            }

            function updateActivityOtherVisibility() {
                if (!activityInput || !activityOtherWrap) return;
                const show = activityInput.value === '__autre__';
                activityOtherWrap.style.display = show ? 'block' : 'none';
                if (!show && activityOtherInput) {
                    activityOtherInput.value = '';
                }
            }
            updateActivityOtherVisibility();
            if (activityInput) {
                activityInput.addEventListener('change', updateActivityOtherVisibility);
            }

            function updateBudgetState() {
                if (!freeInput || !budgetInput) return;
                if (freeInput.checked) {
                    budgetInput.value = '0';
                    budgetInput.setAttribute('readonly', 'readonly');
                } else {
                    budgetInput.removeAttribute('readonly');
                }
            }
            updateBudgetState();
            if (freeInput) {
                freeInput.addEventListener('change', updateBudgetState);
            }

            let questions = [];
            try {
                const parsed = JSON.parse((questionsInput && questionsInput.value) ? questionsInput.value : '[]');
                if (Array.isArray(parsed)) {
                    questions = parsed.filter(function (x) {
                        return typeof x === 'string' && x.trim() !== '';
                    });
                }
            } catch (e) {
                questions = [];
            }

            function syncQuestions() {
                if (questionsInput) {
                    questionsInput.value = JSON.stringify(questions);
                }
            }

            function renderQuestions() {
                if (!questionList) return;
                questionList.innerHTML = '';
                questions.forEach(function (q, idx) {
                    const li = document.createElement('li');
                    const text = document.createElement('span');
                    text.textContent = q;

                    const removeBtn = document.createElement('button');
                    removeBtn.type = 'button';
                    removeBtn.className = 'outline-btn';
                    removeBtn.textContent = 'Retirer';
                    removeBtn.addEventListener('click', function () {
                        questions.splice(idx, 1);
                        syncQuestions();
                        renderQuestions();
                    });

                    li.appendChild(text);
                    li.appendChild(removeBtn);
                    questionList.appendChild(li);
                });
            }

            if (questionAdd && questionInput) {
                questionAdd.addEventListener('click', function () {
                    const value = questionInput.value.trim();
                    if (!value) return;
                    questions.push(value);
                    questionInput.value = '';
                    syncQuestions();
                    renderQuestions();
                });
            }

            renderQuestions();
            syncQuestions();
        });
    })();
</script>
