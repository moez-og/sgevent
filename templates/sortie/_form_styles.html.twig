<style>
    .sortie-form-shell { max-width: 1080px; margin: 0 auto; position: relative; z-index: 1; }
    .sortie-form-card {
        background: linear-gradient(150deg, #ffffff 0%, #f7fbff 100%);
        border: 1px solid rgba(13, 69, 126, 0.12);
        border-radius: 18px;
        padding: 24px;
        box-shadow: 0 14px 40px rgba(12, 38, 75, 0.08);
    }
    .sortie-grid.two-col { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
    .sortie-field { margin-bottom: 16px; }
    .sortie-field label { font-weight: 700; margin-bottom: 6px; display: inline-block; }
    .sortie-field input,
    .sortie-field textarea,
    .sortie-field select {
        width: 100%;
        border: 1px solid rgba(8, 58, 115, 0.25);
        border-radius: 10px;
        padding: 10px 12px;
        background: #fff;
    }
    .sortie-field input.is-invalid,
    .sortie-field textarea.is-invalid,
    .sortie-field select.is-invalid,
    .sortie-field input[aria-invalid="true"],
    .sortie-field textarea[aria-invalid="true"],
    .sortie-field select[aria-invalid="true"] {
        border-color: #c61f3a !important;
        background: linear-gradient(180deg, #fffefe 0%, #fff6f8 100%) !important;
        box-shadow: 0 0 0 4px rgba(198,31,58,.15) !important;
    }
    .sortie-budget-top { display: flex; justify-content: space-between; align-items: center; gap: 12px; }
    .switch-line { display: inline-flex; align-items: center; gap: 8px; font-weight: 600; }
    .sortie-map {
        width: 100%;
        height: clamp(260px, 42vh, 420px);
        border-radius: 14px;
        border: 1px solid rgba(8, 58, 115, 0.25);
        overflow: hidden;
        position: relative;
        z-index: 1;
        background: linear-gradient(180deg, #f8fbff 0%, #eef5ff 100%);
        box-shadow: 0 10px 28px rgba(10, 45, 86, 0.12);
        transition: box-shadow .28s ease, transform .28s ease;
    }
    .sortie-map:hover {
        box-shadow: 0 16px 34px rgba(10, 45, 86, 0.18);
    }
    .sortie-map .leaflet-container {
        width: 100%;
        height: 100%;
        background: transparent;
    }
    .sortie-map .leaflet-pane,
    .sortie-map .leaflet-top,
    .sortie-map .leaflet-bottom,
    .sortie-map .leaflet-control {
        z-index: 2 !important;
    }
    .sortie-map .leaflet-control-zoom a {
        border-radius: 10px;
    }
    .map-hint { margin: 4px 0 10px; color: #3f5874; font-size: 0.93rem; }
    .map-search-box {
        position: relative;
        margin-bottom: 10px;
    }
    .map-search-suggestions {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        right: 0;
        z-index: 30;
        max-height: 260px;
        overflow: auto;
        border: 1px solid rgba(8, 58, 115, 0.18);
        border-radius: 12px;
        background: #fff;
        box-shadow: 0 12px 30px rgba(10, 45, 86, 0.16);
    }
    .map-search-suggestion {
        display: block;
        width: 100%;
        border: 0;
        border-bottom: 1px solid rgba(8, 58, 115, 0.08);
        background: transparent;
        text-align: left;
        padding: 10px 12px;
        cursor: pointer;
        color: #0f2f59;
    }
    .map-search-suggestion:last-child {
        border-bottom: 0;
    }
    .map-search-suggestion:hover,
    .map-search-suggestion:focus {
        background: #eff6ff;
        outline: none;
    }
    .map-search-suggestion small {
        display: block;
        margin-top: 2px;
        color: #5f7896;
        font-size: 0.82rem;
    }
    .map-search-empty {
        padding: 10px 12px;
        color: #5f7896;
        font-size: 0.88rem;
    }
    .question-input-row { display: flex; gap: 10px; margin-bottom: 10px; }
    .question-list { margin: 0; padding: 0; list-style: none; display: grid; gap: 8px; }
    .question-list li {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        background: #fff;
        border: 1px solid rgba(8, 58, 115, 0.15);
        border-radius: 10px;
        padding: 8px 10px;
    }
    .sortie-actions { display: flex; gap: 10px; align-items: center; margin-top: 8px; flex-wrap: wrap; }
    .sortie-form ul { margin: 6px 0 0; color: #b4193f; }
    .sortie-form .ft-error-stack { margin-top: 8px; display: grid; gap: 8px; }
    .sortie-form .ft-field-error {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 9px 11px;
        border-radius: 10px;
        border: 1px solid rgba(198,31,58,.34);
        background: linear-gradient(180deg, #fff8fa 0%, #fff1f4 100%);
        color: #8b1b2c;
        font-size: .86rem;
        font-weight: 600;
        line-height: 1.35;
    }
    .sortie-form .ft-field-error__icon {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #c61f3a, #e44c65);
        color: #fff;
        font-size: .72rem;
        font-weight: 900;
        flex: 0 0 18px;
    }
    .sortie-flash { border-radius: 10px; padding: 10px 12px; margin-bottom: 10px; }
    .sortie-flash-success { background: #e8f8ef; color: #146534; }
    .sortie-flash-error { background: #fdeef0; color: #8f1d2e; }
    .sortie-form-global-errors { margin-bottom: 12px; color: #8f1d2e; }
    .image-preview img { width: 110px; height: 110px; object-fit: cover; border-radius: 12px; margin-top: 10px; }
    .sortie-field .flatpickr-input[readonly] {
        background: #fff;
        cursor: pointer;
    }
    .flatpickr-calendar {
        border-radius: 12px;
        border: 1px solid rgba(8, 58, 115, 0.18);
        box-shadow: 0 16px 34px rgba(10, 45, 86, 0.16);
    }
    @media (max-width: 860px) {
        .sortie-grid.two-col { grid-template-columns: 1fr; }
        .question-input-row { flex-direction: column; }
        .sortie-actions {
            flex-direction: column;
            align-items: stretch;
        }
        .sortie-map {
            height: clamp(240px, 34vh, 320px);
        }
        .sortie-actions .primary-btn,
        .sortie-actions .outline-btn,
        .question-input-row .outline-btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
