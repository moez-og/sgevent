
{% extends 'front/base_front.html.twig' %}

{% block title %}{{ lieu.nom }} | {{ 'front.place_detail.title'|trans }}{% endblock %}

{% block front_content %}
<section>
    {% for message in app.flashes('success') %}
        <div class="users-feedback users-feedback--success" style="margin-bottom:10px;">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="users-feedback users-feedback--error" style="margin-bottom:10px;">{{ message }}</div>
    {% endfor %}

    <!-- Navigation et Breadcrumb -->
    <div class="nav-breadcrumb">
        <a href="{{ path('app_lieux') }}" class="back-btn">← {{ 'front.search.back_home'|trans }}</a>
        <span class="breadcrumb-path">{{ 'nav.home'|trans }} / <strong>{{ lieu.nom }}</strong></span>
    </div>

    <!-- Top Section avec Titre et Actions -->
    <div class="section-head" style="margin:20px 0 24px 0;">
        <div>
            <h1 class="section-title" style="margin-bottom:10px;">{{ lieu.nom }}</h1>
            <div class="badge-group">
                {% if lieu.categorie %}
                    <span class="badge-primary">{{ lieu.categorie|replace({'_':' '})|upper }}</span>
                {% endif %}
                {% if lieu.type %}
                    <span class="badge-secondary">{{ lieu.type|replace({'_':' '})|upper }}</span>
                {% endif %}
                <span class="badge-premium">Premium</span>
            </div>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <button type="button" class="btn-fav" id="favBtn">♥ {{ 'front.place_detail.add_favorite'|trans }}</button>
            <button type="button" class="btn-secondary" onclick="copyShareLink()">↗ {{ 'front.place_detail.share'|trans }}</button>
            {% if lieu.latitude is not null and lieu.longitude is not null %}
                <a href="https://www.google.com/maps?q={{ lieu.latitude }},{{ lieu.longitude }}" target="_blank" rel="noopener" class="btn-maps" style="text-decoration:none;">🗺 {{ 'front.place_detail.maps'|trans }}</a>
            {% endif %}
        </div>
    </div>

    <!-- Galerie et Détails en Grille -->
    <div class="lieu-details-grid">
        <!-- Colonne Gauche: Galerie et Infos -->
        <div class="left-col">
            <!-- Galerie d'images -->
            {% if galleryImages is defined and galleryImages|length > 0 %}
                {% set firstImage = galleryImages|first %}
                {% if firstImage starts with 'http://' or firstImage starts with 'https://' %}
                    {% set firstImageSrc = firstImage %}
                {% elseif firstImage starts with 'theme/' or firstImage starts with 'uploads/' %}
                    {% set firstImageSrc = asset(firstImage) %}
                {% else %}
                    {% set firstImageSrc = asset('uploads/lieux/' ~ firstImage) %}
                {% endif %}
                <div class="gallery-container">
                    <img id="heroImage" src="{{ firstImageSrc }}" alt="{{ lieu.nom }}" class="hero-img">
                    <span class="carousel-counter">1 / {{ galleryImages|length }}</span>
                    <div class="thumbs-row">
                        {% for img in galleryImages %}
                            {% if img starts with 'http://' or img starts with 'https://' %}
                                {% set src = img %}
                            {% elseif img starts with 'theme/' or img starts with 'uploads/' %}
                                {% set src = asset(img) %}
                            {% else %}
                                {% set src = asset('uploads/lieux/' ~ img) %}
                            {% endif %}
                            <img src="{{ src }}" class="thumb-img" alt="Miniature" onclick="setHero('{{ src }}', this)">
                        {% endfor %}
                    </div>
                </div>
            {% else %}
                <div class="img-placeholder">{{ 'front.place_detail.no_image'|trans }}</div>
            {% endif %}

            <!-- À propos -->
            <div class="details-block">
                <h3>{{ 'front.place_detail.about'|trans }}</h3>
                <p>{{ lieu.description ?: ('front.place_detail.no_description'|trans) }}</p>
            </div>

            <!-- Horaires d'ouverture -->
            <div class="details-block">
                <h3>{{ 'front.place_detail.opening_hours'|trans }}</h3>
                {% if horaires is not empty %}
                    <ul class="horaires-list">
                        {% set todayMap = {'lundi': 1, 'mardi': 2, 'mercredi': 3, 'jeudi': 4, 'vendredi': 5, 'samedi': 6, 'dimanche': 0} %}
                        {% set todayNum = 'now'|date('w')|number_format %}
                        {% for h in horaires %}
                            {% set hJour = h.jour|lower %}
                            {% set isToday = todayMap[hJour]|default(-1) == todayNum %}
                            <li class="horaire-item" {% if isToday %}style="background:#fef3c7;padding:8px;border-radius:8px;"{% endif %}>
                                <span class="jour-name">{{ hJour|title }}</span>
                                <span class="jour-status">
                                    {% if isToday %}<span class="badge-today">{{ 'front.place_detail.today'|trans }}</span> {% endif %}
                                    {% if h.ouvert %}
                                        {{ h.heure_ouverture_1 ?: '--:--' }} - {{ h.heure_fermeture_1 ?: '--:--' }}
                                        {% if h.heure_ouverture_2 or h.heure_fermeture_2 %}
                                            / {{ h.heure_ouverture_2 ?: '--:--' }} - {{ h.heure_fermeture_2 ?: '--:--' }}
                                        {% endif %}
                                    {% else %}
                                        <span class="fermé">{{ 'front.place_detail.closed'|trans }}</span>
                                    {% endif %}
                                </span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="muted">{{ 'front.place_detail.no_hours'|trans }}</p>
                {% endif %}
            </div>
        </div>

        <!-- Colonne Droite: Météo et Infos -->
        <div class="right-col">
            <!-- Météo Widget -->
            <div class="app-card weather-card">
                <div class="weather-header">
                    <div class="weather-temp">26°C</div>
                    <div class="weather-icons">☁️📱</div>
                </div>
                <div class="weather-location">{{ lieu.ville }}</div>
                <div class="weather-stats">
                    <div class="weather-stat">
                        <span class="stat-label">💧 {{ 'front.place_detail.humidity'|trans }}</span>
                        <span class="stat-value">47%</span>
                    </div>
                    <div class="weather-stat">
                        <span class="stat-label">💨 {{ 'front.place_detail.wind'|trans }}</span>
                        <span class="stat-value">2.6 m/s</span>
                    </div>
                </div>
            </div>

            <!-- Budget -->
            <div class="app-card budget-card">
                <div class="budget-label">💰 {{ 'front.place_detail.average_budget'|trans }}</div>
                <div class="budget-range">
                    {% if lieu.budget_min is not null or lieu.budget_max is not null %}
                        {{ 'front.place_detail.budget_range'|trans({'%min%': lieu.budget_min|default(0)|number_format(0, ',', ' '), '%max%': lieu.budget_max|default(0)|number_format(0, ',', ' ')}) }}
                    {% else %}
                        {{ 'front.place_detail.not_provided'|trans }}
                    {% endif %}
                </div>
            </div>

            <!-- Informations Contact -->
            <div class="app-card contact-card">
                <h3>{{ 'front.place_detail.contact'|trans }}</h3>
                {% if lieu.telephone %}
                    <div class="contact-item">
                        <span class="contact-icon">📞</span>
                        <a href="tel:{{ lieu.telephone }}" class="contact-link">{{ lieu.telephone }}</a>
                    </div>
                {% endif %}
                {% if lieu.site_web %}
                    <div class="contact-item">
                        <span class="contact-icon">🌐</span>
                        <a href="{{ lieu.site_web }}" target="_blank" rel="noopener" class="contact-link">{{ lieu.site_web }}</a>
                    </div>
                {% endif %}
                {% if lieu.instagram %}
                    <div class="contact-item">
                        <span class="contact-icon">📸</span>
                        <a href="https://instagram.com/{{ lieu.instagram|replace({'@':''}) }}" target="_blank" rel="noopener" class="contact-link">@{{ lieu.instagram|replace({'@':''}) }}</a>
                    </div>
                {% endif %}
                <button class="btn-primary-block">+ {{ 'front.place_detail.add_outing'|trans }}</button>
            </div>

            <!-- Offres liées -->
            {% if offres is not empty %}
            <div class="app-card offres-card">
                <h3>{{ 'front.place_detail.related_offers'|trans }}</h3>
                {% for offre in offres %}
                    <div class="offre-item">
                        <strong>{{ offre.titre }}</strong>
                        {% if offre.pourcentage is not null %}
                            <span class="badge-offre">{{ offre.pourcentage }}%</span>
                        {% endif %}
                        {% if offre.date_fin %}
                            <div class="offre-date">{{ 'front.place_detail.expires_on'|trans }} {{ offre.date_fin|date('d/m/Y') }}</div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </div>

    <!-- Section Avis -->
    <div class="avis-section">
        <div class="avis-header">
            <div>
                <h2>{{ 'front.place_detail.reviews'|trans }} / {{ evaluationStats.total|default(0) }}</h2>
                {% if evaluationStats.moyenne is not null %}
                    <p class="avis-moyenne">⭐ {{ 'front.place_detail.average_rating'|trans }}: {{ evaluationStats.moyenne|round(1) }}/5</p>
                {% endif %}
            </div>
            {% if app.user %}
                {% if not currentUserEvaluation %}
                    <button type="button" class="btn-add-avis" onclick="openAvisModal()">+ {{ 'front.place_detail.add_review'|trans }}</button>
                {% endif %}
            {% else %}
                <a href="{{ path('app_login') }}" class="btn-add-avis" style="text-decoration:none;">{{ 'front.place_detail.login_to_rate'|trans }}</a>
            {% endif %}
        </div>

        <!-- Barre de recherche -->
        <input type="text" id="avisSearchField" class="search-avis" placeholder="{{ 'front.place_detail.search_reviews'|trans }}">

        <!-- Votre avis (si connecté) -->
        {% if app.user %}
            {% if currentUserEvaluation %}
                <div class="my-avis-card">
                    <div class="my-avis-header">
                        <span class="my-avis-badge">{{ 'front.place_detail.your_review'|trans }}</span>
                        <span class="star-rating">⭐ {{ currentUserEvaluation.note }}/5</span>
                    </div>
                    <p class="my-avis-comment">{{ currentUserEvaluation.commentaire ?: ('front.place_detail.no_comment'|trans) }}</p>
                    <div class="my-avis-actions">
                        <button type="button" class="btn-edit-avis" onclick="openEditAvisModal()">✏️ {{ 'common.edit'|trans }}</button>
                        <button type="button" class="btn-delete-avis" onclick="deleteAvis({{ currentUserEvaluation.id }})">🗑️ {{ 'common.delete'|trans }}</button>
                    </div>
                </div>
            {% endif %}
        {% endif %}

        <!-- Liste des avis -->
        <div id="avisList" class="avis-list">
            {% for e in evaluations %}
                {% if not app.user or app.user.id != e.user_id %}
                    <article class="avis-card" data-avis-search="{{ (e.prenom|default('') ~ ' ' ~ e.nom|default('') ~ ' ' ~ e.commentaire|default(''))|lower }}">
                        <div class="avis-card-header">
                            <strong class="avis-author">{{ e.prenom|default(('front.place_detail.user'|trans)) }} {{ e.nom|default('') }}</strong>
                            <span class="avis-rating">⭐ {{ e.note }}/5</span>
                        </div>
                        <p class="avis-text">{{ e.commentaire ?: ('front.place_detail.no_comment_short'|trans) }}</p>
                        <div class="avis-date">{{ (e.updated_at ?: e.date_evaluation)|date('d/m/Y') }}</div>
                    </article>
                {% endif %}
            {% else %}
                <div class="empty-avis">{{ 'front.place_detail.no_reviews'|trans }}</div>
            {% endfor %}
        </div>
    </div>

    <!-- Modal Ajouter/Modifier Avis -->
    <div id="avisModal" class="modal-overlay" style="display:none;">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="modalTitle">{{ 'front.place_detail.add_review'|trans }}</h2>
                <button type="button" class="modal-close" onclick="closeAvisModal()">✕</button>
            </div>

            <form id="avisForm" method="post" class="modal-form">
                <input type="hidden" name="_token" id="formToken" value="">
                <input type="hidden" name="evaluationId" id="formEvaluationId" value="">

                <!-- Étoiles de Note -->
                <div class="form-group">
                    <label>{{ 'front.place_detail.rating'|trans }}</label>
                    <div class="stars-input">
                        <input type="hidden" id="note" name="note" value="0">
                        {% for i in 1..5 %}
                            <span class="star" onclick="setRating({{ i }})" data-value="{{ i }}">★</span>
                        {% endfor %}
                    </div>
                    <div class="rating-display"><span id="ratingText">5</span>/5</div>
                </div>

                <!-- Commentaire -->
                <div class="form-group">
                    <label for="commentaire">{{ 'front.place_detail.write_comment'|trans }}</label>
                    <textarea id="commentaire" name="commentaire" class="modal-textarea" maxlength="500" placeholder="{{ 'front.place_detail.your_experience'|trans }}"></textarea>
                    <div class="char-count"><span id="charCount">0</span> / 500 {{ 'front.place_detail.characters'|trans }}</div>
                </div>

                <!-- Suggestions -->
                <div class="suggestions">
                    <p class="suggestions-title">💡 {{ 'front.place_detail.suggestions'|trans }}</p>
                    <div class="suggestion-tags">
                        <button type="button" class="suggestion-tag" onclick="addSuggestion('Experience absolument parfaite, un lieu exceptionnel...')">Experience absolument parfaite, un lieu exceptiona...</button>
                        <button type="button" class="suggestion-tag" onclick="addSuggestion('Coup de coeur total, tout était parfait du début à...')">Coup de coeur total, tout était parfait du début à...</button>
                        <button type="button" class="suggestion-tag" onclick="addSuggestion('Le meilleur endroit que j\'ai visité, chaque détai...')">Le meilleur endroit que j\'ai visité, chaque détai...</button>
                    </div>
                </div>

                <!-- Boutons -->
                <div class="modal-actions">
                    <button type="submit" class="btn-submit">{{ 'common.save'|trans }}</button>
                    <button type="button" class="btn-cancel" onclick="closeAvisModal()">{{ 'common.cancel'|trans }}</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Form caché pour suppression -->
    <form id="deleteForm" method="post" style="display:none;">
        <input type="hidden" name="_token" value="">
    </form>
</section>

<style>
    /* Navigation et Breadcrumb */
    .nav-breadcrumb {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        font-size: 14px;
    }
    .back-btn {
        padding: 8px 14px;
        background: #fff;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        text-decoration: none;
        color: #0f172a;
        cursor: pointer;
        font-weight: 500;
    }
    .back-btn:hover {
        background: #f1f5f9;
    }
    .breadcrumb-path {
        color: #64748b;
    }
    .breadcrumb-path strong {
        color: #0f172a;
    }

    /* Badges */
    .badge-group {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 8px;
    }
    .badge-primary {
        background: #fef3c7;
        color: #92400e;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }
    .badge-secondary {
        background: #e0e7ff;
        color: #3730a3;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }
    .badge-premium {
        background: #dbeafe;
        color: #0c4a6e;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    /* Boutons */
    .btn-fav, .btn-secondary, .btn-maps {
        padding: 10px 16px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        background: #fff;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
    }
    .btn-fav:hover {
        background: #fef2f2;
        border-color: #fecaca;
        color: #dc2626;
    }
    .btn-secondary:hover, .btn-maps:hover {
        background: #f1f5f9;
        border-color: #94a3b8;
    }
    .btn-primary-block {
        width: 100%;
        padding: 12px;
        border-radius: 10px;
        background: #1e3a8a;
        color: #fff;
        border: none;
        font-weight: 600;
        cursor: pointer;
        margin-top: 12px;
    }
    .btn-primary-block:hover {
        background: #1e40af;
    }

    /* Galerie */
    .gallery-container {
        position: relative;
        background: #f8fafc;
        border-radius: 16px;
        overflow: hidden;
    }
    .carousel-counter {
        position: absolute;
        top: 12px;
        left: 12px;
        background: rgba(0, 0, 0, 0.6);
        color: #fff;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }
    .hero-img {
        width: 100%;
        height: 400px;
        object-fit: cover;
        display: block;
    }
    .thumbs-row {
        display: flex;
        gap: 8px;
        overflow-x: auto;
        padding: 12px;
        background: #fff;
    }
    .thumb-img {
        width: 80px;
        height: 60px;
        object-fit: cover;
        border-radius: 8px;
        border: 2px solid transparent;
        cursor: pointer;
        flex-shrink: 0;
    }
    .thumb-img:hover {
        border-color: #0ea5e9;
    }

    /* Grille Détails */
    .lieu-details-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 24px;
        margin-bottom: 24px;
    }

    /* Bloc Détails */
    .details-block {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 16px;
        margin-top: 16px;
    }
    .details-block h3 {
        margin: 0 0 12px 0;
        font-size: 16px;
        color: #0f172a;
    }
    .details-block p {
        margin: 0;
        color: #475569;
        line-height: 1.5;
    }

    /* Horaires */
    .horaires-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 8px;
    }
    .horaire-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 12px;
        border-radius: 8px;
        background: #fff;
        border: 1px solid #e2e8f0;
    }
    .jour-name {
        font-weight: 600;
        color: #0f172a;
        min-width: 80px;
    }
    .jour-status {
        text-align: right;
        color: #475569;
        font-size: 14px;
    }
    .fermé {
        color: #dc2626;
        font-weight: 600;
    }
    .badge-today {
        background: #fbbf24;
        color: #7c2d12;
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
        margin-right: 8px;
        display: inline-block;
    }

    /* Carte */
    .app-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 16px;
    }

    /* Météo */
    .weather-card {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: #fff;
    }
    .weather-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 12px;
    }
    .weather-temp {
        font-size: 32px;
        font-weight: 700;
    }
    .weather-icons {
        font-size: 24px;
    }
    .weather-location {
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 12px;
    }
    .weather-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid rgba(255, 255, 255, 0.2);
    }
    .weather-stat {
        display: grid;
        gap: 4px;
    }
    .stat-label {
        font-size: 12px;
        opacity: 0.9;
    }
    .stat-value {
        font-size: 16px;
        font-weight: 700;
    }

    /* Budget */
    .budget-card {
        background: #fff;
    }
    .budget-label {
        font-size: 14px;
        color: #64748b;
        font-weight: 600;
        margin-bottom: 8px;
    }
    .budget-range {
        font-size: 16px;
        font-weight: 700;
        color: #0f172a;
    }

    /* Contact */
    .contact-card h3 {
        margin: 0 0 12px 0;
    }
    .contact-item {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
        padding-bottom: 10px;
        border-bottom: 1px solid #e2e8f0;
    }
    .contact-item:last-of-type {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }
    .contact-icon {
        font-size: 18px;
    }
    .contact-link {
        color: #0ea5e9;
        text-decoration: none;
        font-weight: 500;
        word-break: break-all;
    }
    .contact-link:hover {
        color: #0284c7;
        text-decoration: underline;
    }

    /* Section Avis */
    .avis-section {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 24px;
        margin-top: 24px;
    }
    .avis-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 20px;
    }
    .avis-header h2 {
        margin: 0 0 8px 0;
        font-size: 18px;
        color: #0f172a;
    }
    .avis-moyenne {
        margin: 0;
        font-size: 14px;
        color: #64748b;
    }
    .btn-add-avis {
        padding: 10px 16px;
        background: #fbbf24;
        border: none;
        border-radius: 8px;
        color: #78350f;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
    }
    .btn-add-avis:hover {
        background: #f59e0b;
    }

    .search-avis {
        width: 100%;
        max-width: 420px;
        padding: 10px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        font-size: 14px;
        margin-bottom: 20px;
    }
    .search-avis:focus {
        outline: none;
        border-color: #0ea5e9;
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
    }

    /* Votre Avis */
    .my-avis-card {
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 20px;
    }
    .my-avis-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }
    .my-avis-badge {
        background: #fbbf24;
        color: #78350f;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
    }
    .star-rating {
        color: #92400e;
        font-weight: 700;
    }
    .my-avis-comment {
        margin: 10px 0;
        color: #78350f;
        line-height: 1.5;
    }
    .my-avis-actions {
        display: flex;
        gap: 12px;
        margin-top: 12px;
    }
    .btn-edit-avis, .btn-delete-avis {
        padding: 8px 12px;
        border: 1px solid;
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
    }
    .btn-edit-avis {
        border-color: #fbbf24;
        color: #78350f;
    }
    .btn-edit-avis:hover {
        background: #fbbf24;
    }
    .btn-delete-avis {
        border-color: #fca5a5;
        color: #991b1b;
    }
    .btn-delete-avis:hover {
        background: #fee2e2;
    }

    /* Liste Avis */
    .avis-list {
        display: grid;
        gap: 12px;
        margin-top: 16px;
    }
    .avis-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 14px;
    }
    .avis-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }
    .avis-author {
        color: #0f172a;
        font-size: 14px;
    }
    .avis-rating {
        color: #ca8a04;
        font-size: 13px;
        font-weight: 700;
    }
    .avis-text {
        margin: 8px 0;
        color: #475569;
        font-size: 14px;
        line-height: 1.5;
    }
    .avis-date {
        color: #94a3b8;
        font-size: 12px;
    }
    .empty-avis {
        text-align: center;
        padding: 20px;
        color: #94a3b8;
        font-size: 14px;
    }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }
    .modal-content {
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        max-width: 600px;
        width: 90%;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    .modal-header h2 {
        margin: 0;
        font-size: 18px;
        color: #0f172a;
    }
    .modal-close {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #64748b;
    }
    .modal-close:hover {
        color: #0f172a;
    }

    /* Star Rating */
    .stars-input {
        display: flex;
        gap: 12px;
        margin-bottom: 8px;
    }
    .star {
        font-size: 32px;
        cursor: pointer;
        color: #cbd5e1;
        transition: color 0.2s;
    }
    .star:hover, .star.active {
        color: #fbbf24;
    }
    .rating-display {
        font-size: 14px;
        color: #64748b;
        margin-bottom: 16px;
    }
    .rating-display #ratingText {
        font-weight: 700;
        color: #0f172a;
    }

    /* Form */
    .modal-form {
        display: grid;
        gap: 18px;
    }
    .form-group {
        display: grid;
        gap: 8px;
    }
    .form-group label {
        font-weight: 600;
        color: #0f172a;
        font-size: 14px;
    }
    .modal-textarea {
        width: 100%;
        padding: 12px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        font-size: 14px;
        font-family: inherit;
        resize: vertical;
        min-height: 100px;
    }
    .modal-textarea:focus {
        outline: none;
        border-color: #0ea5e9;
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
    }
    .char-count {
        font-size: 12px;
        color: #94a3b8;
    }

    /* Suggestions */
    .suggestions {
        background: #f0f9ff;
        border: 1px solid #bfdbfe;
        border-radius: 10px;
        padding: 12px;
    }
    .suggestions-title {
        margin: 0 0 10px 0;
        font-size: 13px;
        font-weight: 600;
        color: #1e40af;
    }
    .suggestion-tags {
        display: grid;
        gap: 8px;
    }
    .suggestion-tag {
        background: #fff;
        border: 1px solid #bfdbfe;
        border-radius: 8px;
        padding: 10px 12px;
        text-align: left;
        cursor: pointer;
        font-size: 13px;
        color: #1e40af;
        font-weight: 500;
        transition: all 0.2s;
    }
    .suggestion-tag:hover {
        background: #bfdbfe;
        border-color: #0284c7;
    }

    /* Modal Actions */
    .modal-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }
    .btn-submit {
        flex: 1;
        padding: 12px;
        background: #fbbf24;
        color: #78350f;
        border: none;
        border-radius: 10px;
        font-weight: 700;
        cursor: pointer;
    }
    .btn-submit:hover {
        background: #f59e0b;
    }
    .btn-cancel {
        flex: 1;
        padding: 10px;
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
    }
    .btn-cancel:hover {
        background: #e2e8f0;
    }

    /* Offres */
    .offre-item {
        padding: 10px 0;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .offre-item:last-child {
        border-bottom: none;
    }
    .badge-offre {
        background: #fef3c7;
        color: #92400e;
        padding: 4px 10px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 12px;
    }
    .offre-date {
        font-size: 12px;
        color: #64748b;
        margin-top: 4px;
    }

    /* Messages d'erreur/succès */
    .users-feedback {
        border-radius: 10px;
        padding: 12px 14px;
        border: 1px solid transparent;
        font-weight: 600;
    }
    .users-feedback--success {
        border-color: #86efac;
        background: #f0fdf4;
        color: #166534;
    }
    .users-feedback--error {
        border-color: #fca5a5;
        background: #fef2f2;
        color: #991b1b;
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .lieu-details-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }
        .hero-img {
            height: 300px;
        }
        .avis-header {
            flex-direction: column;
            gap: 12px;
        }
        .btn-add-avis {
            width: 100%;
            text-align: center;
        }
    }

    @media (max-width: 640px) {
        .section-head {
            flex-direction: column;
            gap: 16px;
        }
        .modal-content {
            width: 95%;
            padding: 16px;
        }
        .hero-img {
            height: 250px;
        }
    }
</style>

<script>
    const lieuId = {{ lieu.id }};
    const currentUserId = {{ app.user ? app.user.id : 'null' }};
    {% if currentUserEvaluation %}
        const currentEvaluationId = {{ currentUserEvaluation.id }};
        const currentEvaluationNote = {{ currentUserEvaluation.note }};
        const currentEvaluationCommentaire = `{{ currentUserEvaluation.commentaire|escape('js') }}`;
        const editAvisUrl = '{{ path('app_lieu_evaluation_update', {id: lieu.id, evaluationId: currentUserEvaluation.id}) }}';
        const editAvisToken = '{{ csrf_token('front_eval_update_' ~ currentUserEvaluation.id) }}';
        const deleteAvisUrl = '{{ path('app_lieu_evaluation_delete', {id: lieu.id, evaluationId: currentUserEvaluation.id}) }}';
        const deleteAvisToken = '{{ csrf_token('front_eval_delete_' ~ currentUserEvaluation.id) }}';
    {% else %}
        const currentEvaluationId = null;
        const currentEvaluationNote = 0;
        const currentEvaluationCommentaire = '';
    {% endif %}
    const createAvisUrl = '{{ path('app_lieu_evaluation_create', {id: lieu.id}) }}';
    const createAvisToken = '{{ csrf_token('front_eval_create_' ~ lieu.id) }}';

    function openAvisModal() {
        const modal = document.getElementById('avisModal');
        document.getElementById('modalTitle').textContent = 'Ajouter un avis';
        document.getElementById('avisForm').action = createAvisUrl;
        document.getElementById('formToken').value = createAvisToken;
        document.getElementById('formEvaluationId').value = '';
        resetForm();
        modal.style.display = 'flex';
    }

    function openEditAvisModal() {
        if (!currentEvaluationId) {
            alert('Erreur: Aucun avis à modifier.');
            return;
        }
        const modal = document.getElementById('avisModal');
        document.getElementById('modalTitle').textContent = 'Modifier mon avis';
        document.getElementById('avisForm').action = editAvisUrl;
        document.getElementById('formToken').value = editAvisToken;
        document.getElementById('formEvaluationId').value = currentEvaluationId;
        document.getElementById('note').value = currentEvaluationNote;
        document.getElementById('commentaire').value = currentEvaluationCommentaire;
        updateRatingDisplay(currentEvaluationNote);
        updateCharCount();
        highlightStars(currentEvaluationNote);
        modal.style.display = 'flex';
    }

    function closeAvisModal() {
        document.getElementById('avisModal').style.display = 'none';
    }

    function setRating(value) {
        document.getElementById('note').value = value;
        updateRatingDisplay(value);
        highlightStars(value);
    }

    function updateRatingDisplay(value) {
        document.getElementById('ratingText').textContent = value;
    }

    function highlightStars(rating) {
        document.querySelectorAll('.star').forEach((star, index) => {
            if (index < rating) {
                star.classList.add('active');
            } else {
                star.classList.remove('active');
            }
        });
    }

    function updateCharCount() {
        const textarea = document.getElementById('commentaire');
        const count = textarea.value.length;
        document.getElementById('charCount').textContent = count;
    }

    function resetForm() {
        document.getElementById('avisForm').reset();
        document.getElementById('note').value = 0;
        document.getElementById('commentaire').value = '';
        updateRatingDisplay(0);
        updateCharCount();
        document.querySelectorAll('.star').forEach(star => star.classList.remove('active'));
    }

    function addSuggestion(text) {
        document.getElementById('commentaire').value = text;
        updateCharCount();
    }

    function deleteAvis(evaluationId) {
        if (!confirm('Êtes-vous sûr de vouloir supprimer votre avis ?')) return;
        const form = document.getElementById('deleteForm');
        form.method = 'post';
        form.action = deleteAvisUrl;
        form.querySelector('input[name="_token"]').value = deleteAvisToken;
        form.submit();
    }

    function setHero(src, thumb) {
        const hero = document.getElementById('heroImage');
        if (hero) {
            hero.src = src;
        }
        document.querySelectorAll('.thumb-img').forEach(function (el) {
            el.style.borderColor = 'transparent';
        });
        if (thumb) {
            thumb.style.borderColor = '#0ea5e9';
        }
    }

    function copyShareLink() {
        navigator.clipboard.writeText(window.location.href).then(function () {
            alert('Lien copié dans le presse-papiers.');
        }).catch(function () {
            alert('Impossible de copier le lien.');
        });
    }

    // Search dans les avis
    const avisSearchField = document.getElementById('avisSearchField');
    if (avisSearchField) {
        avisSearchField.addEventListener('input', function () {
            const query = this.value.toLowerCase().trim();
            document.querySelectorAll('.avis-card').forEach(function (card) {
                const text = card.getAttribute('data-avis-search') || '';
                card.style.display = text.includes(query) ? '' : 'none';
            });
        });
    }

    // Update char count en temps réel
    const textarea = document.getElementById('commentaire');
    if (textarea) {
        textarea.addEventListener('input', updateCharCount);
    }

    // Fermer le modal en cliquant en dehors
    window.addEventListener('click', function (event) {
        const modal = document.getElementById('avisModal');
        if (event.target === modal) {
            closeAvisModal();
        }
    });

    // Form submission pour avis
    document.getElementById('avisForm').addEventListener('submit', function (e) {
        e.preventDefault();
        const note = document.getElementById('note').value;
        const commentaire = document.getElementById('commentaire').value;

        if (!note || note < 1 || note > 5) {
            alert('Veuillez sélectionner une note entre 1 et 5.');
            return;
        }

        if (commentaire.length < 10 && commentaire.length > 0) {
            alert('Le commentaire doit contenir au moins 10 caractères.');
            return;
        }

        this.submit();
    });
</script>
{% endblock %}
