{% extends 'front/base_front.html.twig' %}

{% block title %}Événements | Fin Tokhroj{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('theme/css/evenement-enhance.css') }}?v=v2">
{% endblock %}

{% block front_content %}
<section>
    {% set filters = filters|default({ q: '', type: '', prix: '' }) %}
    <div class="section-head">
        <div>
            <h1 class="section-title">Événements à venir</h1>
            <p class="section-subtitle">Découvrez et rejoignez les meilleurs événements</p>
        </div>
        <a href="{{ path('app_home') }}" class="outline-btn">Retour accueil</a>
    </div>

    {# ───────────── Bannière IA — Recommandations personnalisées ───────────── #}
    {% if app.user %}
        <div class="ai-reco-banner" role="region" aria-label="Recommandations IA">
            <div class="ai-reco-banner__icon" aria-hidden="true">🤖</div>
            <div class="ai-reco-banner__text">
                <h3>Suggestions personnalisées pour vous</h3>
                <p>Notre IA analyse vos inscriptions pour dénicher les événements qui vous correspondent.</p>
            </div>
            <button type="button" class="ai-reco-banner__cta" id="btnAiReco" aria-expanded="false" aria-controls="aiRecoPanel">
                <span class="sparkle" aria-hidden="true">✨</span>
                <span id="btnAiRecoLabel">Voir les suggestions</span>
            </button>
            <a href="{{ path('app_evenements_recommandations') }}" class="ai-reco-banner__cta" style="background: rgba(255,255,255,0.2); color: #fff;">
                Page complète →
            </a>
        </div>

        <div class="ai-reco-panel" id="aiRecoPanel" role="region" aria-live="polite">
            <div class="ai-reco-panel__head">
                <h4 class="ai-reco-panel__title">
                    <span aria-hidden="true">🎯</span>
                    Sélection basée sur vos intérêts
                </h4>
                <span class="ai-reco-panel__mode" id="aiRecoMode">Analyse…</span>
            </div>
            <div class="ai-reco-chips" id="aiRecoChips"></div>
            <div id="aiRecoList">
                <div style="text-align: center; padding: 20px; color: var(--ev-muted);">
                    Chargement des recommandations…
                </div>
            </div>
        </div>
    {% endif %}

    {# ───────────── Filtres ───────────── #}
    <div class="listing-card event-filter-card">
        <div class="section-head" style="margin-bottom: 10px;">
            <div>
                <h2 class="section-title" style="font-size: 1.1rem;">Recherche et filtres</h2>
                <p class="section-subtitle">Affiner les événements proposés.</p>
            </div>
            <a href="{{ path('app_evenements') }}" class="outline-btn">Réinitialiser</a>
        </div>
        <form method="get" class="event-filter-grid">
            <div class="event-filter-field">
                <label>Recherche</label>
                <input type="text" name="q" value="{{ filters.q }}" placeholder="Titre ou lieu">
            </div>
            <div class="event-filter-field">
                <label>Type</label>
                <select name="type">
                    <option value="">Tous les types</option>
                    <option value="PUBLIC" {{ filters.type == 'PUBLIC' ? 'selected' : '' }}>Public</option>
                    <option value="PRIVE" {{ filters.type == 'PRIVE' ? 'selected' : '' }}>Privé</option>
                </select>
            </div>
            <div class="event-filter-field">
                <label>Prix</label>
                <select name="prix">
                    <option value="">Tous</option>
                    <option value="gratuit" {{ filters.prix == 'gratuit' ? 'selected' : '' }}>Gratuit</option>
                    <option value="payant" {{ filters.prix == 'payant' ? 'selected' : '' }}>Payant</option>
                </select>
            </div>
            <div class="event-filter-field event-filter-actions">
                <button type="submit" class="cta-btn">Filtrer</button>
            </div>
        </form>
    </div>

    {# ───────────── Grille d'événements ───────────── #}
    <div class="ev-grid">
        {% for event in events %}
            {% set eventDateDebut = event.dateDebut|default(event.date_debut|default(null)) %}
            {% set eventDateFin = event.dateFin|default(event.date_fin|default(null)) %}
            {% set eventCapacite = event.capaciteMax|default(event.capacite_max|default(null)) %}
            {% set placesRest = event.placesRestantes|default(eventCapacite ?? 0) %}

            {% set rawImage = event.imageUrl|default(event.image_url|default('')) %}
            {% if rawImage and (rawImage starts with 'http://' or rawImage starts with 'https://') %}
                {% set imageSrc = rawImage %}
            {% elseif rawImage and (rawImage starts with '/theme/' or rawImage starts with '/uploads/') %}
                {% set imageSrc = rawImage %}
            {% elseif rawImage and (rawImage starts with 'theme/' or rawImage starts with 'uploads/') %}
                {% set imageSrc = asset(rawImage) %}
            {% elseif rawImage %}
                {% set imageSrc = asset('uploads/evenements/' ~ rawImage) %}
            {% else %}
                {% set imageSrc = asset('theme/images/logo.png') %}
            {% endif %}

            <article class="ev-card" style="animation-delay: {{ loop.index0 * 0.05 }}s;">
                <div class="ev-card__cover">
                    <img src="{{ imageSrc }}" alt="{{ event.titre }}" loading="lazy"
                         onerror="this.onerror=null;this.src='{{ asset('theme/images/logo.png') }}';">
                    <div class="ev-card__badges">
                        {% if event.prix > 0 %}
                            <span class="ev-badge is-paid">💰 {{ event.prix }} TND</span>
                        {% else %}
                            <span class="ev-badge is-free">🎉 Gratuit</span>
                        {% endif %}
                        {% if eventCapacite and placesRest <= (eventCapacite * 0.2) and placesRest > 0 %}
                            <span class="ev-badge is-hot">🔥 Bientôt complet</span>
                        {% elseif placesRest == 0 %}
                            <span class="ev-badge" style="background: rgba(239,68,68,0.95); color: #fff;">❌ Complet</span>
                        {% endif %}
                    </div>
                </div>

                <div class="ev-card__body">
                    <h3 class="ev-card__title">{{ event.titre }}</h3>
                    {% if event.description %}
                        <p class="ev-card__lead">{{ event.description|striptags|slice(0, 120) }}{% if event.description|length > 120 %}…{% endif %}</p>
                    {% endif %}

                    <div class="ev-card__meta">
                        <span>🗓 {{ eventDateDebut ? eventDateDebut|date('d/m/Y H:i') : 'Date à confirmer' }}</span>
                        {% if event.lieu is defined and event.lieu %}
                            <span>📍 {{ event.lieu.nom }}</span>
                        {% elseif event.lieu_nom is defined and event.lieu_nom %}
                            <span>📍 {{ event.lieu_nom }}</span>
                        {% endif %}
                        <span>👥 {{ placesRest }} place{{ placesRest > 1 ? 's' : '' }}</span>
                    </div>
                </div>

                <div class="ev-card__foot">
                    <a href="{{ path('app_evenement_show', {id: event.id}) }}" class="ev-card__cta">
                        Voir les détails
                        <span aria-hidden="true">→</span>
                    </a>
                </div>
            </article>
        {% else %}
            <div class="ev-empty" style="grid-column: 1 / -1;">
                <span class="ev-empty__emoji" aria-hidden="true">📭</span>
                Aucun événement disponible pour le moment.
                {% if filters.q or filters.type or filters.prix %}
                    <br><a href="{{ path('app_evenements') }}" style="color: var(--ev-accent); font-weight: 700;">Réinitialiser les filtres</a>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</section>

{% if app.user %}
<script>
(function () {
    const btn = document.getElementById('btnAiReco');
    const btnLabel = document.getElementById('btnAiRecoLabel');
    const panel = document.getElementById('aiRecoPanel');
    const listEl = document.getElementById('aiRecoList');
    const modeEl = document.getElementById('aiRecoMode');
    const chipsEl = document.getElementById('aiRecoChips');
    if (!btn || !panel) return;

    let loaded = false;

    function escapeHtml(s) {
        return String(s ?? '').replace(/[&<>"']/g, c => ({
            '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
        })[c]);
    }

    function weatherIconSvg(label) {
        const l = (label || '').toLowerCase();
        if (l.includes('pluie') || l.includes('averse')) {
            return '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 13a5 5 0 0 0-10 0H5a7 7 0 0 1 14 0zM8 16l-1 3m5-3l-1 3m5-3l-1 3"/></svg>';
        }
        if (l.includes('orage')) {
            return '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L4 14h6l-1 8 10-14h-7z"/></svg>';
        }
        if (l.includes('nuage') || l.includes('couvert')) {
            return '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 19a4 4 0 0 1 0-8 6 6 0 0 1 11.6-1A4 4 0 0 1 18 19z"/></svg>';
        }
        if (l.includes('neige')) {
            return '<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="2"/><path d="M12 2v20M2 12h20"/></svg>';
        }
        return '<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="5"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>';
    }

    function renderRecommendations(data) {
        const modeTxt = {
            'gemini':  { label: 'IA Gemini',   cls: 'is-gemini'  },
            'local':   { label: 'Algorithme',   cls: ''            },
            'popular': { label: 'Populaires',   cls: 'is-popular' },
        }[data.mode] || { label: 'Suggestion', cls: '' };
        modeEl.textContent = modeTxt.label;
        modeEl.className = 'ai-reco-panel__mode ' + modeTxt.cls;

        chipsEl.innerHTML = '';
        (data.interests || []).slice(0, 8).forEach(kw => {
            const chip = document.createElement('span');
            chip.className = 'ai-reco-chip';
            chip.textContent = '#' + kw;
            chipsEl.appendChild(chip);
        });
        if (data.analysis) {
            const note = document.createElement('span');
            note.className = 'ai-reco-chip';
            note.style.background = 'rgba(15,31,46,0.06)';
            note.style.color = 'var(--ev-muted)';
            note.textContent = data.analysis;
            chipsEl.appendChild(note);
        }

        if (!data.events || data.events.length === 0) {
            listEl.innerHTML = '<div style="text-align:center; padding:24px; color:var(--ev-muted);">Aucune recommandation disponible. Inscrivez-vous à des événements pour personnaliser vos suggestions !</div>';
            return;
        }
        const html = data.events.map(ev => {
            const img = ev.image_url || "{{ asset('theme/images/logo.png') }}";
            let wx = '';
            if (ev.weather && ev.weather.label) {
                wx = '<span class="wx-chip">' + weatherIconSvg(ev.weather.label) +
                     (ev.weather.temp !== null ? ev.weather.temp + '° ' : '') +
                     escapeHtml(ev.weather.label) + '</span>';
            }
            return '' +
                '<a class="ai-reco-row" href="' + escapeHtml(ev.url) + '">' +
                  '<div class="ai-reco-row__img">' +
                    '<img src="' + escapeHtml(img) + '" alt="" loading="lazy" ' +
                       'onerror="this.onerror=null;this.src=\'{{ asset('theme/images/logo.png') }}\';">' +
                  '</div>' +
                  '<div class="ai-reco-row__body">' +
                    '<h4>' + escapeHtml(ev.titre) + '</h4>' +
                    '<p>' +
                      '<span>🗓 ' + escapeHtml(ev.date_debut_fr || '') + '</span>' +
                      (ev.lieu ? '<span>📍 ' + escapeHtml(ev.lieu) + '</span>' : '') +
                      (ev.prix > 0 ? '<span>💰 ' + ev.prix + ' TND</span>' : '<span>🎉 Gratuit</span>') +
                      wx +
                    '</p>' +
                  '</div>' +
                  '<span class="ai-reco-row__cta">Voir →</span>' +
                '</a>';
        }).join('');
        listEl.innerHTML = html;
    }

    async function loadRecommendations() {
        listEl.innerHTML = '<div style="text-align:center; padding:20px; color:var(--ev-muted);"><span style="display:inline-block; width:16px; height:16px; border:2px solid rgba(11,92,120,0.2); border-top-color:var(--ev-accent); border-radius:50%; animation:aiSpin 0.7s linear infinite; vertical-align:middle; margin-right:8px;"></span>L\'IA analyse vos préférences…</div>';
        try {
            const res = await fetch('{{ path('app_evenements_recommandations_json') }}?limit=6', {
                credentials: 'same-origin',
                headers: { 'Accept': 'application/json' },
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();
            renderRecommendations(data);
            loaded = true;
        } catch (e) {
            listEl.innerHTML = '<div style="text-align:center; padding:20px; color:#b91c1c;">❌ Impossible de charger les suggestions. Veuillez réessayer.</div>';
        }
    }

    btn.addEventListener('click', async () => {
        const isOpen = panel.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', String(isOpen));
        btnLabel.textContent = isOpen ? 'Masquer les suggestions' : 'Voir les suggestions';
        if (isOpen && !loaded) {
            await loadRecommendations();
        }
        if (isOpen) {
            panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
    });
})();
</script>
{% endif %}

<style>
    .event-filter-card { margin-bottom: 18px; }
    .event-filter-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
    }
    .event-filter-field { display: grid; gap: 6px; }
    .event-filter-field label {
        font-size: 13px;
        font-weight: 700;
        color: #334155;
    }
    .event-filter-field input,
    .event-filter-field select {
        width: 100%;
        border: 1px solid #cbd5e1;
        border-radius: 12px;
        padding: 10px 12px;
        font-size: 14px;
        background: #fff;
        color: #0f172a;
        outline: none;
        transition: border-color .25s, box-shadow .25s;
    }
    .event-filter-field input:focus,
    .event-filter-field select:focus {
        border-color: #38bdf8;
        box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.15);
    }
    .event-filter-actions { display: flex; align-items: end; }
</style>
{% endblock %}
