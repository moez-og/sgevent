{% extends 'front/base_front.html.twig' %}

{% block title %}Tickets | {{ inscription.evenement.titre }}{% endblock %}

{% block front_content %}
<section style="max-width: 980px; margin: 30px auto; padding: 0 20px;">
    <div class="section-head">
        <div>
            <h1 class="section-title">Vos tickets</h1>
            <p class="section-subtitle">{{ inscription.evenement.titre }}</p>
        </div>
        <a href="{{ path('app_mon_profil_inscriptions') }}" class="outline-btn">Retour à mes inscriptions</a>
    </div>

    <div class="listing-card" style="padding: 18px;">
        <div style="display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 16px;">
            <div style="font-weight: 700;">Paiement confirmé</div>
            <div style="display: flex; gap: 10px; align-items: center;">
                <span class="badge-soft">{{ tickets|length }} ticket{{ tickets|length > 1 ? 's' : '' }}</span>
                <a href="{{ path('app_inscription_tickets_pdf', {id: inscription.id}) }}" class="outline-btn" style="padding: 8px 12px;">Télécharger PDF</a>
            </div>
        </div>

        <div style="display: grid; gap: 12px;">
            {% for ticket in tickets %}
                <div style="border: 1px dashed #cbd5f5; padding: 14px; border-radius: 12px; background: #f8fafc;">
                    <div style="display: flex; justify-content: space-between; align-items: center; gap: 8px;">
                        <div>
                            <div style="font-weight: 700;">{{ ticket.getNumeroTicketFinal() }}</div>
                            <div style="font-size: 13px; color: #64748b;">Émis le {{ ticket.date|date('d/m/Y') }}</div>
                        </div>
                        <div style="text-align: right;">
                            <div style="font-size: 12px; color: #64748b;">Code validation</div>
                            <div style="font-weight: 700;">{{ ticket.codeValidation }}</div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="empty-state">Aucun ticket généré.</div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
